# ============================================
# NEXORAFLOW — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o GitHub!
# ============================================

# 1. Telegram — obtenha em t.me/BotFather
TELEGRAM_TOKEN=

# 2. Supabase — em app.supabase.com > Settings > API
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
# 3. Google Gemini — em aistudio.google.com/apikey (grátis)
GEMINI_KEY=

# 4. URL pública do ngrok (preencha após rodar: npx ngrok http 3000)
#    Exemplo: https://abc123.ngrok-free.app
WEBHOOK_URL=

# Porta local (padrão: 3000)
PORT=

RESET_PASSWORD=12x12e144

# Web Push (VAPID) — gerado automaticamente
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
